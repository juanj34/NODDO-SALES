{
  "name": "nodesites",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "verify:vercel": "tsx scripts/verify-vercel-token.ts",
    "create-admin": "tsx scripts/create-first-admin.ts",
    "setup:prod": "bash scripts/quick-setup.sh",
    "security:audit": "npm audit --audit-level=moderate",
    "security:audit:fix": "npm audit fix",
    "security:full": "npm run security:audit && npm run lint && npm run typecheck",
    "db:migrate": "npx supabase db push",
    "postinstall": "cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs public/pdf.worker.min.mjs 2>/dev/null || true"
  },
