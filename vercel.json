{
  "crons": [
    {
      "path": "/api/exchange-rates/cron",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/weekly-resource-report",
      "schedule": "0 13 * * 1"
    }
  ],
  "functions": {
    "pages/api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=4096"
    }
  }
}
