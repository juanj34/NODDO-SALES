# ═══════════════════════════════════════════════════════════════════════
# NODDO Platform Environment Variables
# ═══════════════════════════════════════════════════════════════════════

# ─── Core Application ─────────────────────────────────────────────────

# Root domain for the platform
# DEV:  localhost:3000
# PROD: noddo.io
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# Application URL (for emails, redirects, etc.)
# DEV:  http://localhost:3000
# PROD: https://noddo.io
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Maps ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token

# ─── Email (Resend) ───────────────────────────────────────────────────

RESEND_API_KEY=re_your-resend-key

# ─── GoHighLevel CRM ──────────────────────────────────────────────────

# GHL API credentials
GHL_PIT_TOKEN=your-ghl-personal-integration-token
GHL_LOCATION_ID=your-ghl-location-id
GHL_PIPELINE_ID=your-ghl-pipeline-id

# GHL Contact Tags (for lead categorization)
GHL_TAG_LEAD=lead-noddo
GHL_TAG_DEMO_SCHEDULED=demo-agendado
GHL_TAG_DEMO_NO_SHOW=demo-no-show
GHL_TAG_CONTACT_FORM=contacto-web
GHL_TAG_PLAN_PROYECTO=plan-proyecto
GHL_TAG_PLAN_STUDIO=plan-studio
GHL_TAG_PLAN_ENTERPRISE=plan-enterprise

# GHL Custom Fields (for additional data)
GHL_CUSTOM_FIELD_PLAN_INTERES=your-custom-field-id-1
GHL_CUSTOM_FIELD_PAGINA_ORIGEN=your-custom-field-id-2

# GHL Pipeline Stages (opportunity movement)
# NOTE: Get these IDs from your GHL pipeline configuration
GHL_STAGE_NUEVO_PROSPECTO=your-stage-id-1
GHL_STAGE_DEMO_AGENDADO=your-stage-id-2
GHL_STAGE_DEMO_REALIZADO=
GHL_STAGE_PROPUESTA_ENVIADA=
GHL_STAGE_NEGOCIACION=
GHL_STAGE_CERRADO_GANADO=
GHL_STAGE_CERRADO_PERDIDO=

# ─── Marketing & Tracking ─────────────────────────────────────────────

# Meta Pixel (Facebook Ads)
NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id
META_CONVERSION_API_TOKEN=your-capi-token

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ─── AI & Media ───────────────────────────────────────────────────────

# Google Gemini (for AI features)
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# Cloudflare (for media storage)
CLOUDFLARE_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=your-bucket-name
CLOUDFLARE_STREAM_CUSTOMER_CODE=your-stream-code

# ─── Vercel (for custom domains) ──────────────────────────────────────

VERCEL_API_TOKEN=your-vercel-token
VERCEL_TEAM_ID=your-team-id
VERCEL_PROJECT_ID=your-project-id

# ─── Error Monitoring (Sentry) ────────────────────────────────────────

# Sentry DSN (public - used by client and server)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Sentry build-time configuration (required for source map upload)
# Get these from: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-organization-slug
SENTRY_PROJECT=your-project-slug

# ─── Production-Specific ──────────────────────────────────────────────

# WhatsApp support number (E.164 format: +[country][number])
# Used in no-show follow-ups and support links
# DEV:  +1234567890 (test number)
# PROD: +971585407848 (or your actual support number)
WHATSAPP_SUPPORT_NUMBER=+1234567890

# Meeting link for demos (Google Meet, Zoom, etc.)
MEETING_LINK=https://meet.google.com/your-link

# Admin notification email (recibe reportes semanales y alertas)
ADMIN_EMAIL=admin@noddo.io

# Cron job secret (para proteger endpoints de cron)
CRON_SECRET=your-random-secret-here

# ─── Optional / Future ────────────────────────────────────────────────

# Stripe (for payments - not yet implemented)
# STRIPE_SECRET_KEY=sk_test_your-key
# STRIPE_WEBHOOK_SECRET=whsec_your-secret
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# Upstash Redis (for rate limiting and caching)
# Get free tier at: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXXXxxx

# Upstash API (para reportes de uso en emails semanales - opcional)
# Get from: https://console.upstash.com/account/api
UPSTASH_API_TOKEN=your-upstash-api-token
UPSTASH_EMAIL=your-upstash-email

# ─── Security & Anti-Spam ─────────────────────────────────────────────

# Google reCAPTCHA v3 (protects lead forms from spam)
# Get keys at: https://www.google.com/recaptcha/admin
# Site key is public, secret key is server-side only
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lxxx...
RECAPTCHA_SECRET_KEY=6Lxxx...

# Security alert email (receives notifications for suspicious activity)
SECURITY_ALERT_EMAIL=seguridad@noddo.io

# ─── Customer Support (Crisp Chat) ────────────────────────────────────
# Get free account at: https://crisp.chat/en/
# Website ID can be found in Settings → Setup instructions
NEXT_PUBLIC_CRISP_WEBSITE_ID=your-crisp-website-id
